# Drizzle / server writes — Supabase Postgres connection string
# Project Settings → Database → Connection string (transaction pooler, port 6543)
DATABASE_URL=

# Supabase browser client — auth, realtime, storage
# Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only (never exposed to the browser): mints signed URLs for private
# voice recordings. Project Settings → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=

# Paystack — ₦1,000 charge to open a sign-out space. Dashboard → Settings → API
# Keys & Webhooks. Use test keys (sk_test_… / pk_test_…) in development.
PAYSTACK_SECRET_KEY=
VITE_PAYSTACK_PUBLIC_KEY=

# Canonical production origin, no trailing slash. Used to build absolute
# og:image / og:url tags so shared links unfurl (WhatsApp, Slack, X, etc.).
# Defaults to https://signmeout.app if unset — set this to your real domain.
VITE_SITE_URL=

# Resend — order + feedback emails. Dashboard → API Keys. The FROM address must
# be on a Resend-verified domain in production (the resend.dev sandbox sender
# only delivers to the Resend account owner's email).
# FEEDBACK_INBOX_EMAIL falls back to ORDER_INBOX_EMAIL when unset.
RESEND_API_KEY=
ORDER_FROM_EMAIL=
ORDER_INBOX_EMAIL=
FEEDBACK_INBOX_EMAIL=
